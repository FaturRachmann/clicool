# {{ theme_name }} theme for bash
# Generated by clicool v{{ theme_version }}
# {{ timestamp }}

# CLICOOL Theme: {{ theme_name }}
# Colors
{% if colors %}
{% for name, color in colors.items() %}
{% if color and color.startswith('#') %}
# {{ name }}: {{ color }}
{% endif %}
{% endfor %}
{% endif %}

# Prompt template
PS1='{{ prompt_template }}'

# Git branch function
clicool_git_branch() {
    local branch
    if branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null); then
        if [ "$branch" = "HEAD" ]; then
            branch=$(git describe --tags --exact-match 2>/dev/null || git rev-parse --short HEAD)
        fi
        echo " $branch"
    fi
}

# Git status function
clicool_git_status() {
    local status=""
    local git_status=$(git status --porcelain 2>/dev/null)

    if [ -n "$git_status" ]; then
        if echo "$git_status" | grep -q "^M"; then
            status="${status}*"
        fi
        if echo "$git_status" | grep -q "^A"; then
            status="${status}+"
        fi
        if echo "$git_status" | grep -q "^??"; then
            status="${status}?"
        fi
        echo " $status"
    fi
}

# Exit code function
clicool_exit_code() {
    local exit_code=$?
    if [ $exit_code -ne 0 ]; then
        echo " [$exit_code]"
    fi
}

# Time function
clicool_time() {
    date +"{{ time_format }}"
}

# Kubernetes context function
clicool_k8s_context() {
    if command -v kubectl &>/dev/null; then
        local context=$(kubectl config current-context 2>/dev/null)
        if [ -n "$context" ]; then
            echo " ☸️  $context"
        fi
    fi
}

# Docker status function
clicool_docker_status() {
    if command -v docker &>/dev/null; then
        local count=$(docker ps --format '{{.ID}}' 2>/dev/null | wc -l | tr -d ' ')
        if [ "$count" -gt 0 ]; then
            echo " 🐳 $count"
        fi
    fi
}

# AWS profile function
clicool_aws_profile() {
    if [ -n "$AWS_PROFILE" ]; then
        echo " ☁️  $AWS_PROFILE"
    elif [ -n "$AWS_DEFAULT_PROFILE" ]; then
        echo " ☁️  $AWS_DEFAULT_PROFILE"
    fi
}

# Virtualenv function
clicool_venv() {
    if [ -n "$VIRTUAL_ENV" ]; then
        local venv_name=$(basename "$VIRTUAL_ENV")
        echo " 🐍 $venv_name"
    fi
}
