# {{ theme_name }} theme for fish
# Generated by clicool v{{ theme_version }}
# {{ timestamp }}

# CLICOOL Theme: {{ theme_name }}

# Prompt function
function fish_prompt
    set -l last_status $status
    
    # Build prompt
    echo -n "{{ prompt_template }}"
    
    # Exit code
    if [ $last_status -ne 0 ]
        echo -n " [$last_status]"
    end
end

# Git branch function
function clicool_git_branch
    set -l branch (git rev-parse --abbrev-ref HEAD 2>/dev/null)
    if [ "$branch" = "HEAD" ]
        set branch (git describe --tags --exact-match 2>/dev/null; or git rev-parse --short HEAD)
    end
    if [ -n "$branch" ]
        echo " $branch"
    end
end

# Git status function
function clicool_git_status
    set -l git_status (git status --porcelain 2>/dev/null)
    set -l status ""
    
    if [ -n "$git_status" ]
        if string match -q "^M*" "$git_status"
            set status "${status}*"
        end
        if string match -q "^A*" "$git_status"
            set status "${status}+"
        end
        if string match -q "^??" "$git_status"
            set status "${status}?"
        end
        echo " $status"
    end
end

# Time function
function clicool_time
    date +"{{ time_format }}"
end

# Kubernetes context function
function clicool_k8s_context
    if command -v kubectl >/dev/null 2>&1
        set -l context (kubectl config current-context 2>/dev/null)
        if [ -n "$context" ]
            echo " ☸️  $context"
        end
    end
end

# Docker status function
function clicool_docker_status
    if command -v docker >/dev/null 2>&1
        set -l count (docker ps --format '{{.ID}}' 2>/dev/null | wc -l | string trim)
        if [ "$count" -gt 0 ]
            echo " 🐳 $count"
        end
    end
end

# AWS profile function
function clicool_aws_profile
    if [ -n "$AWS_PROFILE" ]
        echo " ☁️  $AWS_PROFILE"
    else if [ -n "$AWS_DEFAULT_PROFILE" ]
        echo " ☁️  $AWS_DEFAULT_PROFILE"
    end
end

# Virtualenv function
function clicool_venv
    if [ -n "$VIRTUAL_ENV" ]
        set -l venv_name (basename "$VIRTUAL_ENV")
        echo " 🐍 $venv_name"
    end
end
